# ===========================================
# Marketing Automation Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API Key (Required for content generation)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Telegram Bot (Required for Telegram automation)
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHANNEL_ID=@your_channel_name

# LinkedIn (Required for LinkedIn automation)
# Use your LinkedIn login email
LINKEDIN_EMAIL=your-email@gmail.com
LINKEDIN_PASSWORD=your-password
# Alternative: Copy 'li_at' cookie from browser (more reliable)
LINKEDIN_COOKIE=your-li_at-cookie-value

# Email - Resend (Free: 100 emails/day)
# Get from: https://resend.com
RESEND_API_KEY=re_your-key-here
FROM_EMAIL=hello@yourdomain.com

# Optional: Your Details
FOUNDER_NAME=Yash
FOUNDER_LINKEDIN=https://linkedin.com/in/yourprofile
